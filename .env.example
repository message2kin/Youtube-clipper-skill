# YouTube Clipper 環境變量配置示例
# 複製此文件為 .env 並填入實際值

# ============================================================================
# FFmpeg 配置
# ============================================================================

# FFmpeg 可執行文件路徑（可選，留空則自動檢測）
# macOS (Apple Silicon): /opt/homebrew/opt/ffmpeg-full/bin/ffmpeg
# macOS (Intel): /usr/local/opt/ffmpeg-full/bin/ffmpeg
# Linux: /usr/bin/ffmpeg
FFMPEG_PATH=

# 字幕燒錄樣式
SUBTITLE_FONT_SIZE=24
SUBTITLE_MARGIN_V=30

# ============================================================================
# 輸出配置
# ============================================================================

# 輸出目錄（默認: 當前工作目錄下的 youtube-clips/）
OUTPUT_DIR=./youtube-clips

# 影片質量限制（最高分辨率）
# 選項: 720, 1080, 1440, 2160 (4K)
MAX_VIDEO_HEIGHT=1080

# ============================================================================
# 字幕翻譯配置
# ============================================================================

# 批量翻譯大小（每批翻譯的字幕條數）
# 推薦: 20-25
TRANSLATION_BATCH_SIZE=20

# 目標翻譯語言
# 選項: 中文, 日語, 韓語, 西班牙語, 等
TARGET_LANGUAGE=中文

# ============================================================================
# 章節分析配置
# ============================================================================

# 目標章節時長（秒）
# 推薦: 180 (3分鐘) - 300 (5分鐘)
TARGET_CHAPTER_DURATION=180

# ============================================================================
# yt-dlp 配置
# ============================================================================

# yt-dlp 代理設置（如果需要）
# 格式: http://proxy-server:port 或 socks5://proxy-server:port
YT_DLP_PROXY=

# yt-dlp 下載速率限制（如果需要）
# 格式: 50K, 4.2M, 等
YT_DLP_RATE_LIMIT=

# ============================================================================
# 高級配置
# ============================================================================

# 臨時文件目錄（用於解決路徑空格問題）
# 留空則使用系統默認臨時目錄
TEMP_DIR=

# 是否保留臨時文件（調試用）
# 選項: true, false
KEEP_TEMP_FILES=false

# 日誌級別
# 選項: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# 注意事項
# ============================================================================

# 1. 此文件中的配置是可選的，如果不設置，Skill 會使用默認值
# 2. 路徑可以使用 ~ 表示用户主目錄
# 3. 環境變量值不需要引號
# 4. 以 # 開頭的行是註釋
# 5. 修改配置後需要重啓 Claude Code 才能生效
